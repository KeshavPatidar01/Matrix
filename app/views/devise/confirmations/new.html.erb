<div class="min-h-screen bg-black flex flex-col justify-center py-12 sm:px-6 lg:px-8 font-mono relative overflow-hidden">
  
  <div class="absolute inset-0 z-0 pointer-events-none opacity-20" 
       style="background-image: linear-gradient(#00FF41 1px, transparent 1px), linear-gradient(90deg, #00FF41 1px, transparent 1px); background-size: 30px 30px;">
  </div>

  <div class="sm:mx-auto sm:w-full sm:max-w-md relative z-10">
    <div class="mx-auto w-12 h-12 flex items-end justify-center gap-1 mb-4">
       <div class="w-2 h-3 bg-[#00FF41] animate-pulse"></div>
       <div class="w-2 h-5 bg-[#00FF41] animate-pulse delay-75"></div>
       <div class="w-2 h-8 bg-[#00FF41] animate-pulse delay-150"></div>
    </div>
    
    <h2 class="mt-2 text-center text-2xl font-bold text-[#00FF41] tracking-[0.2em] text-shadow-glow uppercase border-b border-[#003B00] pb-4">
      > VERIFICATION_ERROR
    </h2>
    <p class="mt-4 text-center text-sm text-[#00FF41]/70">
      <span class="mr-1">></span> Signal lost. Re-enter identity for packet retransmission.
    </p>
  </div>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md relative z-10">
    <div class="bg-black border border-[#00FF41] py-8 px-4 shadow-[0_0_20px_rgba(0,255,65,0.15)] relative sm:rounded-none sm:px-10 hover:shadow-[0_0_30px_rgba(0,255,65,0.3)] transition duration-500">
      
      <div class="absolute top-0 left-0 w-2 h-2 bg-[#00FF41]"></div>
      <div class="absolute top-0 right-0 w-2 h-2 bg-[#00FF41]"></div>
      <div class="absolute bottom-0 left-0 w-2 h-2 bg-[#00FF41]"></div>
      <div class="absolute bottom-0 right-0 w-2 h-2 bg-[#00FF41]"></div>

      <%= form_for(resource, as: resource_name, url: confirmation_path(resource_name), html: { method: :post }) do |f| %>
        
        <div class="text-red-500 font-mono text-xs mb-4">
          <%= render "devise/shared/error_messages", resource: resource %>
        </div>

        <div class="space-y-6">
          
          <div>
            <%= f.label :email, "DESTINATION_EMAIL:", class: "block text-xs font-bold text-[#00FF41] uppercase tracking-wider mb-2" %>
            <div class="relative">
              <%= f.email_field :email, autofocus: true, autocomplete: "email", 
                  value: (resource.pending_reconfirmation? ? resource.unconfirmed_email : resource.email),
                  class: "appearance-none block w-full px-4 py-3 bg-black border border-[#003B00] text-[#00FF41] placeholder-[#00FF41]/30 shadow-inner focus:outline-none focus:border-[#00FF41] focus:ring-1 focus:ring-[#00FF41] sm:text-sm transition duration-150 rounded-none",
                  placeholder: "Enter registered email..." %>
            </div>
          </div>

          <div class="pt-2">
            <%= f.submit "RETRANSMIT_VERIFICATION_CODE", 
                class: "w-full flex justify-center py-3 px-4 border border-[#00FF41] rounded-none shadow-[0_0_10px_rgba(0,255,65,0.2)] text-xs font-bold text-[#00FF41] bg-black hover:bg-[#00FF41] hover:text-black focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#00FF41] focus:ring-offset-black cursor-pointer transition duration-300 ease-in-out transform hover:scale-[1.02] uppercase tracking-widest" %>
          </div>

        </div>
      <% end %>

      <div class="mt-8">
        <div class="relative">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-[#003B00]"></div>
          </div>
          <div class="relative flex justify-center text-sm">
            <span class="px-2 bg-black text-[#00FF41]/50 uppercase text-xs tracking-widest">
              Alternate_Protocols
            </span>
          </div>
        </div>
        
        <div class="mt-6 flex justify-center text-sm matrix-links">
           <div class="text-[#00FF41] hover:text-white transition-colors duration-200">
             <%= render "devise/shared/links" %>
           </div>
        </div>
      </div>

    </div>
  </div>
</div>

<style>
  /* Glow Effect */
  .text-shadow-glow {
    text-shadow: 0 0 10px #00FF41;
  }
  
  /* Link Styling for Devise Shared Links */
  .matrix-links a {
    color: #00FF41;
    text-decoration: none;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 0 10px;
    padding-bottom: 2px;
    border-bottom: 1px dotted transparent;
    transition: all 0.3s;
  }
  
  .matrix-links a:hover {
    color: white;
    text-shadow: 0 0 8px #00FF41;
    border-bottom: 1px dotted #00FF41;
  }
  
</style>