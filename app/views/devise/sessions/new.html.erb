<style>
  /* Since we cannot use JS to generate random characters, 
     we use a CSS background pattern that simulates vertical 'digital rain' lines 
     and animate the background position downwards.
  */
  .matrix-bg {
    background-color: #000000;
    background-image: linear-gradient(0deg, transparent 24%, rgba(0, 255, 65, .3) 25%, rgba(0, 255, 65, .3) 26%, transparent 27%, transparent 74%, rgba(0, 255, 65, .3) 75%, rgba(0, 255, 65, .3) 76%, transparent 77%, transparent), linear-gradient(90deg, transparent 24%, rgba(0, 255, 65, .3) 25%, rgba(0, 255, 65, .3) 26%, transparent 27%, transparent 74%, rgba(0, 255, 65, .3) 75%, rgba(0, 255, 65, .3) 76%, transparent 77%, transparent);
    background-size: 50px 50px;
    animation: matrix-fall 4s linear infinite;
  }

  @keyframes matrix-fall {
    0% { background-position: 0 0, 0 0; }
    100% { background-position: 0 1000px, 0 1000px; }
  }

  /* Custom Matrix Glow Helper */
  .matrix-shadow {
    box-shadow: 0 0 15px rgba(0, 255, 65, 0.5);
  }
  
  /* Input autofill fix for Chrome to keep it black */
  input:-webkit-autofill,
  input:-webkit-autofill:hover, 
  input:-webkit-autofill:focus, 
  input:-webkit-autofill:active{
      -webkit-box-shadow: 0 0 0 30px #0a0a0a inset !important;
      -webkit-text-fill-color: #00ff41 !important;
      transition: background-color 5000s ease-in-out 0s;
  }
</style>

<div class="min-h-screen matrix-bg flex flex-col justify-center py-12 sm:px-6 lg:px-8 font-mono relative overflow-hidden">
  
  <div class="absolute inset-0 bg-black opacity-80 z-0"></div>

  <div class="sm:mx-auto sm:w-full sm:max-w-md z-10 relative">
    <h2 class="mt-6 text-center text-3xl font-bold text-[#00ff41] tracking-wider uppercase drop-shadow-[0_0_5px_rgba(0,255,65,0.8)]">
      Wake Up....
    </h2>
    <p class="mt-2 text-center text-sm text-green-700 animate-pulse">
      The Matrix has you. Sign in to exit.
    </p>
  </div>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md z-10 relative">
    <div class="bg-black/90 py-8 px-4 border border-green-800 matrix-shadow sm:rounded-lg sm:px-10 transform transition duration-500 hover:border-[#00ff41]">
      
      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="space-y-6">
          
          <div>
            <%= f.label :email, "USER_ID // EMAIL", class: "block text-xs font-bold text-green-600 uppercase tracking-widest" %>
            <div class="mt-1">
              <%= f.email_field :email, autofocus: true, autocomplete: "email", 
                  placeholder: "enter_matrix_id",
                  class: "appearance-none block w-full px-4 py-3 border border-green-900 bg-gray-900/50 rounded-none shadow-sm placeholder-green-900 text-[#00ff41] focus:outline-none focus:ring-1 focus:ring-[#00ff41] focus:border-[#00ff41] focus:bg-black sm:text-sm transition duration-150" %>
            </div>
          </div>

          <div>
            <%= f.label :password, "ACCESS_CODE // PASSWORD", class: "block text-xs font-bold text-green-600 uppercase tracking-widest" %>
            <div class="mt-1">
              <%= f.password_field :password, autocomplete: "current-password", 
                  placeholder: "********",
                  class: "appearance-none block w-full px-4 py-3 border border-green-900 bg-gray-900/50 rounded-none shadow-sm placeholder-green-900 text-[#00ff41] focus:outline-none focus:ring-1 focus:ring-[#00ff41] focus:border-[#00ff41] focus:bg-black sm:text-sm transition duration-150" %>
            </div>
          </div>
          
          <% if devise_mapping.rememberable? %>
            <div class="flex items-center justify-between">
              <div class="flex items-center">
                <%= f.check_box :remember_me, class: "h-4 w-4 text-[#00ff41] bg-black border-green-700 rounded focus:ring-offset-black focus:ring-[#00ff41]" %>
                <%= f.label :remember_me, "Stay Jacked In", class: "ml-2 block text-xs text-green-600 uppercase" %>
              </div>
            </div>
          <% end %>

          <div class="pt-4">
            <%= f.submit "INITIATE_LOGIN_SEQUENCE", 
                class: "w-full flex justify-center py-3 px-4 border border-[#00ff41] text-sm font-bold uppercase tracking-widest text-[#00ff41] bg-transparent hover:bg-[#00ff41] hover:text-black hover:shadow-[0_0_20px_#00ff41] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-black focus:ring-green-500 cursor-pointer transition duration-300 ease-in-out" %>
          </div>

        </div>
      <% end %>

      <div class="mt-8">
        <div class="relative">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-green-900"></div>
          </div>
          <div class="relative flex justify-center text-sm">
            <span class="px-2 bg-black text-green-800 text-xs uppercase">
              System Options
            </span>
          </div>
        </div>
        
        <div class="mt-4 flex justify-center text-xs space-x-4 text-green-600">
             <style>
               .devise-links a { color: #047857; text-decoration: none; transition: color 0.3s; }
               .devise-links a:hover { color: #00ff41; text-shadow: 0 0 5px #00ff41; }
             </style>
             <div class="devise-links">
                <%= render "devise/shared/links" %>
             </div>
        </div>
      </div>

    </div>
  </div>
</div>