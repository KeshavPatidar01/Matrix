<div class="min-h-screen bg-black w-full pt-24 pb-12 font-mono relative overflow-hidden">
  
  <div class="absolute inset-0 pointer-events-none opacity-20" 
       style="background-image: linear-gradient(#00FF41 1px, transparent 1px), linear-gradient(90deg, #00FF41 1px, transparent 1px); background-size: 40px 40px;">
  </div>

  <div class="max-w-xl w-full mx-auto relative z-10">
    
    <div class="bg-black border border-[#00FF41] shadow-[0_0_15px_rgba(0,255,65,0.3)] p-8 relative">
      
      <div class="absolute top-0 left-0 w-4 h-4 border-t-2 border-l-2 border-[#00FF41]"></div>
      <div class="absolute top-0 right-0 w-4 h-4 border-t-2 border-r-2 border-[#00FF41]"></div>
      <div class="absolute bottom-0 left-0 w-4 h-4 border-b-2 border-l-2 border-[#00FF41]"></div>
      <div class="absolute bottom-0 right-0 w-4 h-4 border-b-2 border-r-2 border-[#00FF41]"></div>

      <h2 class="text-2xl mb-8 text-center text-[#00FF41] uppercase tracking-[0.2em] text-shadow-glow border-b border-[#003B00] pb-4">
        > Config_User: <%= resource_name.to_s.upcase %>
      </h2>

      <div class="w-full mx-auto">
        <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
          
          <div class="text-red-500 text-xs mb-6">
            <%= render "devise/shared/error_messages", resource: resource %>
          </div>

          <div class="field mb-6 group">
            <%= f.label :email, "USER_EMAIL:", class: "block text-xs font-bold text-[#00FF41] mb-2 tracking-widest" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", 
                class: "w-full bg-black border border-[#003B00] text-[#00FF41] p-3 focus:outline-none focus:border-[#00FF41] focus:shadow-[0_0_10px_#00FF41] transition-all duration-300 placeholder-green-900" %>
          </div>

          <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
            <div class="mb-6 p-2 border border-yellow-600 text-yellow-500 text-xs">
              [PENDING_CONFIRMATION]: <%= resource.unconfirmed_email %>
            </div>
          <% end %>

          <div class="border-l-2 border-[#003B00] pl-4 mb-6">
            <div class="field mb-4">
              <%= f.label :password, "NEW_PASSWORD:", class: "block text-xs font-bold text-[#00FF41] mb-1 tracking-widest" %>
              <i class="block text-[10px] text-[#00FF41]/50 mb-2">// Leave blank to keep current configuration</i>
              
              <%= f.password_field :password, autocomplete: "new-password", 
                  class: "w-full bg-black border border-[#003B00] text-[#00FF41] p-3 focus:outline-none focus:border-[#00FF41] focus:shadow-[0_0_10px_#00FF41] transition-all duration-300" %>
              
              <% if @minimum_password_length %>
                <em class="text-[10px] text-[#00FF41]/40 block mt-1">
                  * Requirement: <%= @minimum_password_length %> chars min
                </em>
              <% end %>
            </div>

            <div class="field">
              <%= f.label :password_confirmation, "CONFIRM_NEW_PASSWORD:", class: "block text-xs font-bold text-[#00FF41] mb-2 tracking-widest" %>
              <%= f.password_field :password_confirmation, autocomplete: "new-password", 
                  class: "w-full bg-black border border-[#003B00] text-[#00FF41] p-3 focus:outline-none focus:border-[#00FF41] focus:shadow-[0_0_10px_#00FF41] transition-all duration-300" %>
            </div>
          </div>

          <div class="field mb-8">
            <%= f.label :current_password, "AUTHORIZATION_KEY (CURRENT PASSWORD):", class: "block text-xs font-bold text-[#00FF41] mb-1 tracking-widest" %>
            <i class="block text-[10px] text-[#00FF41]/50 mb-2">// Required to commit changes</i>
            <%= f.password_field :current_password, autocomplete: "current-password", 
                class: "w-full bg-black border border-[#00FF41] text-[#00FF41] p-3 focus:outline-none focus:bg-[#001100] shadow-[inset_0_0_5px_#00FF41]" %>
          </div>

          <div class="actions">
            <%= f.submit "RUN_UPDATE_SEQUENCE", 
                class: "w-full py-3 px-4 border border-[#00FF41] bg-black text-[#00FF41] font-bold uppercase tracking-widest hover:bg-[#00FF41] hover:text-black cursor-pointer transition-all duration-300 shadow-[0_0_10px_rgba(0,255,65,0.2)] hover:shadow-[0_0_20px_#00FF41]" %>
          </div>
        <% end %>

        <div class="mt-6 text-center">
          <%= link_to :back, class: "text-xs text-[#00FF41]/60 hover:text-[#00FF41] hover:underline tracking-widest" do %>
            << ABORT_AND_RETURN
          <% end %>
        </div>

      </div>
    </div>

    <div class="mt-12 border border-red-900/50 p-6 bg-black/50 relative group hover:border-red-600 transition-colors duration-500">
       <h3 class="text-red-600 text-sm font-bold uppercase tracking-widest mb-4 flex items-center">
         <span class="animate-pulse mr-2">!</span> TERMINAL_COMMANDS
       </h3>
       
       <div class="flex flex-col sm:flex-row gap-4 items-center justify-between">
         <span class="text-red-500/60 text-xs">Dissatisfied with the simulation?</span>
         
         <%= button_to registration_path(resource_name), 
             data: { confirm: "WARNING: This action is irreversible. Proceed with deletion?", turbo_confirm: "Are you sure?" }, 
             method: :delete, 
             class: "border border-red-700 text-red-700 px-4 py-2 text-xs uppercase hover:bg-red-600 hover:text-black hover:shadow-[0_0_15px_red] transition-all duration-300" do %>
           [ EXECUTE_SELF_DESTRUCT ]
         <% end %>
       </div>
    </div>
    
  </div>
</div>

<style>
  .text-shadow-glow {
    text-shadow: 0 0 10px #00FF41;
  }
  
</style>