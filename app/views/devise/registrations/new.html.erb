<div class="min-h-screen bg-black flex flex-col justify-center py-12 sm:px-6 lg:px-8 relative overflow-hidden font-mono">
  
  <div class="absolute inset-0 z-0 pointer-events-none opacity-20" 
       style="background-image: linear-gradient(#00FF41 1px, transparent 1px), linear-gradient(90deg, #00FF41 1px, transparent 1px); background-size: 30px 30px;">
  </div>

  <div class="sm:mx-auto sm:w-full sm:max-w-md relative z-10">
    <div class="mx-auto h-12 w-12 border border-[#00FF41] flex items-center justify-center rounded-full shadow-[0_0_15px_#00FF41] p-18">
      <span class="text-[#00FF41]  font-bold ">Defeat Matrix</span>
    </div>

    <h2 class="mt-6 text-center text-3xl font-bold text-[#00FF41] uppercase tracking-widest text-shadow-glow">
      > Initialize_User
    </h2>
    <p class="mt-2 text-center text-sm text-[#00FF41]/70">
      <span class="animate-pulse">_</span> Join the construct.
    </p>
  </div>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md relative z-10">
    <div class="bg-black/80 backdrop-blur-sm py-8 px-4 border border-[#00FF41] shadow-[0_0_20px_rgba(0,255,65,0.2)] sm:rounded-none sm:px-10 transition duration-500 hover:shadow-[0_0_30px_rgba(0,255,65,0.4)]">
      
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <div class="text-red-500 font-mono text-sm mb-4">
          <%= render "devise/shared/error_messages", resource: resource %>
        </div>

        <div class="space-y-6">
          
          <div>
            <%= f.label :email, "ENTER_EMAIL:", class: "block text-xs font-bold text-[#00FF41] uppercase tracking-wider" %>
            <div class="mt-1">
              <%= f.email_field :email, autofocus: true, autocomplete: "email", 
                  class: "appearance-none block w-full px-4 py-3 bg-black border border-[#003B00] text-[#00FF41] placeholder-[#00FF41]/30 rounded-none shadow-inner focus:outline-none focus:ring-1 focus:ring-[#00FF41] focus:border-[#00FF41] sm:text-sm transition duration-150 font-mono", placeholder: "neo@matrix.com" %>
            </div>
          </div>

          <div>
            <div class="flex justify-between items-center">
              <%= f.label :password, "SET_PASSWORD:", class: "block text-xs font-bold text-[#00FF41] uppercase tracking-wider" %>
              <% if @minimum_password_length %>
                <span class="text-[10px] text-[#00FF41]/60 font-medium">
                  [MIN_LENGTH: <%= @minimum_password_length %>]
                </span>
              <% end %>
            </div>
            <div class="mt-1">
              <%= f.password_field :password, autocomplete: "new-password", 
                  class: "appearance-none block w-full px-4 py-3 bg-black border border-[#003B00] text-[#00FF41] placeholder-[#00FF41]/30 rounded-none shadow-inner focus:outline-none focus:ring-1 focus:ring-[#00FF41] focus:border-[#00FF41] sm:text-sm transition duration-150 font-mono" %>
            </div>
          </div>

          <div>
            <%= f.label :password_confirmation, "CONFIRM_PASSWORD:", class: "block text-xs font-bold text-[#00FF41] uppercase tracking-wider" %>
            <div class="mt-1">
              <%= f.password_field :password_confirmation, autocomplete: "new-password", 
                  class: "appearance-none block w-full px-4 py-3 bg-black border border-[#003B00] text-[#00FF41] placeholder-[#00FF41]/30 rounded-none shadow-inner focus:outline-none focus:ring-1 focus:ring-[#00FF41] focus:border-[#00FF41] sm:text-sm transition duration-150 font-mono" %>
            </div>
          </div>

          <div class="pt-4">
            <%= f.submit "EXECUTE_REGISTRATION", 
                class: "w-full flex justify-center py-3 px-4 border border-[#00FF41] rounded-none shadow-[0_0_10px_#00FF41] text-sm font-bold text-[#00FF41] bg-black hover:bg-[#00FF41] hover:text-black focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#00FF41] focus:ring-offset-black cursor-pointer transition-all duration-300 transform hover:scale-[1.02] uppercase tracking-widest" %>
          </div>

        </div>
      <% end %>

      <div class="mt-8">
        <div class="relative">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-[#003B00]"></div>
          </div>
          <div class="relative flex justify-center text-sm">
            <span class="px-2 bg-black text-[#00FF41]/50 uppercase text-xs">
              System_Options
            </span>
          </div>
        </div>

        <div class="mt-6 flex justify-center text-sm matrix-links">
           <div class="text-[#00FF41] hover:text-white transition-colors duration-200">
             <%= render "devise/shared/links" %>
           </div>
        </div>
      </div>
      
    </div>
  </div>
</div>

<style>
  /* Custom Matrix Glow Utilities */
  .text-shadow-glow {
    text-shadow: 0 0 10px #00FF41;
  }
  
  /* Styling Devise Links specifically if they are plain anchors */
  .matrix-links a {
    color: #00FF41;
    text-decoration: none;
    font-size: 0.8rem;
    text-transform: uppercase;
    margin: 0 10px;
    border-bottom: 1px solid transparent;
    transition: all 0.3s;
  }
  
  .matrix-links a:hover {
    color: white;
    text-shadow: 0 0 8px #00FF41;
    border-bottom: 1px solid #00FF41;
  }
</style>