<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "DSA/NeuroLogic" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= javascript_importmap_tags %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    
    <style>
      .matrix-toast {
        animation: slideIn 0.5s ease-out forwards;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.8);
      }
      .matrix-toast.fade-out {
        animation: glitchOut 0.5s forwards;
      }

      /* Slide In Animation */
      @keyframes slideIn {
        from { transform: translateX(100%); opacity: 0; }
        to { transform: translateX(0); opacity: 1; }
      }

      /* Glitch Out Animation */
      @keyframes glitchOut {
        0% { clip-path: inset(0 0 0 0); transform: translateX(0); }
        20% { clip-path: inset(10% 0 80% 0); transform: translateX(-5px); }
        40% { clip-path: inset(80% 0 10% 0); transform: translateX(5px); }
        60% { clip-path: inset(40% 0 40% 0); transform: translateX(-5px); }
        100% { opacity: 0; transform: translateX(20px); }
      }
    </style>
  </head>

  <body class="bg-gray-900 text-white"> <main class="relative min-h-screen">
      
      <div id="toast-container" class="fixed pt-20 right-5 z-50 flex flex-col gap-4 max-w-sm w-full font-mono text-sm pointer-events-none">
        
        <% if notice.present? %>
          <div class="matrix-toast bg-black border border-[#00FF41] text-[#00FF41] p-4 rounded shadow-[0_0_10px_#00FF41] pointer-events-auto relative overflow-hidden group">
            <div class="absolute inset-0 opacity-10" style="background-image: linear-gradient(#00FF41 1px, transparent 1px), linear-gradient(90deg, #00FF41 1px, transparent 1px); background-size: 10px 10px;"></div>
            
            <div class="relative z-10 flex justify-between items-start">
              <div>
                <strong class="block text-xs uppercase tracking-widest border-b border-[#00FF41] mb-1 pb-1 w-max">
                  > System_Notice
                </strong>
                <p><%= notice %></p>
              </div>
              <button onclick="this.parentElement.parentElement.remove()" class="text-[#00FF41] hover:text-white font-bold ml-4">
                [X]
              </button>
            </div>
          </div>
        <% end %>

        <% if alert.present? %>
          <div class="matrix-toast bg-black border border-red-500 text-red-500 p-4 rounded shadow-[0_0_10px_red] pointer-events-auto relative overflow-hidden group">
             <div class="absolute inset-0 opacity-10" style="background-image: linear-gradient(red 1px, transparent 1px), linear-gradient(90deg, red 1px, transparent 1px); background-size: 10px 10px;"></div>

            <div class="relative z-10 flex justify-between items-start">
              <div>
                <strong class="block text-xs uppercase tracking-widest border-b border-red-500 mb-1 pb-1 w-max">
                  > System_Failure
                </strong>
                <p><%= alert %></p>
              </div>
              <button onclick="this.parentElement.parentElement.remove()" class="text-red-500 hover:text-white font-bold ml-4">
                [X]
              </button>
            </div>
          </div>
        <% end %>

      </div>

      <%= render partial: "layouts/navbar" %>
   
      <%= yield %>

      <%= render partial: "layouts/footer" %>
      
    </main>

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const toasts = document.querySelectorAll('.matrix-toast');
        
        toasts.forEach(toast => {
          // Remove toast after 4 seconds
          setTimeout(() => {
            toast.classList.add('fade-out');
            // Wait for animation to finish before removing from DOM
            toast.addEventListener('animationend', () => {
              toast.remove();
            });
          }, 4000); 
        });
      });
    </script>

  </body>
</html>
