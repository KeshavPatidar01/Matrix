<%# Suggested location: app/views/shared/_navbar.html.erb %>
<style>
  @import url('https://fonts.googleapis.com/css2?family=VT323&display=swap');

  /* --- MATRIX NAVBAR STYLES --- */
  .matrix-nav-font {
    font-family: 'VT323', monospace;
    letter-spacing: 1px;
  }

  /* Animated underline for desktop links (Now Green) */
  .nav-link {
    position: relative;
    display: inline-block;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    width: 0;
    height: 2px;
    left: 0;
    bottom: -2px;
    background-color: #00ff00; /* Neon Green */
    box-shadow: 0 0 5px #00ff00;
    transition: width 0.3s ease-in-out;
  }
  .nav-link:hover::after {
    width: 100%;
  }

  /* Hover Lift Effect */
  .hover-lift:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px -3px rgba(0, 255, 0, 0.3);
  }

  /* Matrix Button Style */
  .btn-matrix-nav {
    background-color: black;
    border: 1px solid #00ff00;
    color: #00ff00;
    transition: all 0.3s;
  }
  .btn-matrix-nav:hover {
    background-color: #00ff00;
    color: black;
    box-shadow: 0 0 10px #00ff00;
  }

  /* Filter to turn Logo Green */
  .matrix-logo-filter {
    filter: brightness(8) 
  }
</style>

<header class="bg-black border-b border-green-900 shadow-[0_4px_20px_-5px_rgba(0,255,0,0.1)] sticky top-0 z-50 transition-all duration-300 matrix-nav-font" data-controller="navbar">
    <nav class="container mx-auto px-6 py-4 flex justify-between items-center">
        
        <div class="flex items-center"> 
            <%= link_to root_path, class:"flex items-center group", data: { turbo: false } do %> 
                <%# Applied filter to make logo green, and a hover glow effect %>
                <%= image_tag "logo.png", class:"h-14 matrix-logo-filter transition-all duration-300" %>
            <% end %>
        </div>

        <%# Create Notes Button (Visible if signed in) %>
        <% if user_signed_in? %>
            <%= link_to "Create Notes", new_note_path, data: { turbo: false },
                class: "hidden md:inline-block ml-12 px-4 py-2 rounded text-sm font-bold btn-matrix-nav" %>
        <% end %>

        <div class="hidden gap-6 md:flex items-center ml-auto">
            <%= link_to "Home", pages_home_path, class:"nav-link text-green-500 hover:text-white font-xl transition-colors duration-300" %>
            
            <%= link_to "Exercises", pages_brain_path,  data: {turbo: false}, class:"nav-link text-green-500 hover:text-white font-xl transition-colors duration-300" %>
            
            <%= link_to "Language", pages_language_path, class:"nav-link text-green-500 hover:text-white font-xl transition-colors duration-300" %>
            
            <%= link_to "DSA Roadmap", pages_roadmap_path, data: { turbo: false }, class:"nav-link text-green-500 hover:text-white font-xl transition-colors duration-300" %>
            
            <% if user_signed_in? %>
                <%= link_to "Notes", notes_path, class:"nav-link text-green-500 hover:text-white font-xl transition-colors duration-300" %>
                
                <%= button_to "Exit(Sign Out)", destroy_user_session_path, method: :delete, class:"hover-lift ml-4 btn-matrix-nav px-5 py-2 rounded-full font-bold uppercase tracking-wider text-sm" %>
            <% else %>
                <%= link_to "Jack In (Sign In)", new_user_session_path, class:"hover-lift ml-4 btn-matrix-nav px-5 py-2 rounded-full font-bold uppercase tracking-wider text-sm" %>
            <% end %>
        </div>

        <div class="cursor-pointer md:hidden">
            <button id="mobile-menu-button" class="text-green-500 focus:outline-none hover:text-white transition-colors" data-action="click->navbar#toggles">
                <svg class="w-8 h-8 cursor-pointer drop-shadow-[0_0_5px_rgba(0,255,0,0.5)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
                </svg>
            </button>
        </div>
    </nav>

    <div data-navbar-target="menu" id="mobile-menu" class="hidden md:hidden bg-black border-t border-green-900 shadow-2xl transition-all duration-300">
        <div class="px-4 pt-4 pb-6 space-y-2 font-semibold text-green-500">
            
            <% if user_signed_in? %>
                 <%= link_to "Create Notes", new_note_path, data: { turbo: false }, class: "block w-full text-center mb-4 btn-matrix-nav py-2 rounded" %>
            <% end %>

            <%= link_to "Home", pages_home_path, class:"block px-3 py-2 rounded-md text-lg hover:text-black hover:bg-green-500 transition-all duration-300" %>
            
            <%= link_to "Exercises", pages_brain_path, data: { turbo: false }, class:"block px-3 py-2 rounded-md text-lg hover:text-black hover:bg-green-500 transition-all duration-300" %>
            
            <%= link_to "Notes", notes_path, class:"block px-3 py-2 rounded-md text-lg hover:text-black hover:bg-green-500 transition-all duration-300" %>
            
            <%= link_to "Language", pages_language_path, data: { turbo: false }, class:"block px-3 py-2 rounded-md text-lg hover:text-black hover:bg-green-500 transition-all duration-300" %>
            
            <%= link_to "DSA Roadmap", pages_roadmap_path, data: { turbo: false }, class:"block px-3 py-2 rounded-md text-lg hover:text-black hover:bg-green-500 transition-all duration-300" %>
            
            <div class="pt-4 border-t border-green-900 mt-2">
                <% if user_signed_in? %>
                    <%= button_to "Exit(But You Can't Escape Matrix)", destroy_user_session_path, method: :delete, class:"block w-full text-left px-3 py-2 rounded-md text-lg text-red-400 hover:bg-red-900 hover:text-white transition-all duration-300" %>
                <% else %>
                    <%= link_to "Jack In (Sign In)", new_user_session_path, class:"block px-3 py-2 rounded-md text-lg btn-matrix-nav text-center" %>
                <% end %>
            </div>
        </div>
    </div>
</header>

<script>  
document.addEventListener("turbo:load", () => {
  console.log("Matrix Navbar loaded");
});
</script>