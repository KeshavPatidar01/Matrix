<style>
  @import url('https://fonts.googleapis.com/css2?family=VT323&display=swap');

  /* --- 1. GLOBAL FONTS & COLORS --- */
  body, h1, h2, h3, p, a {
    font-family: 'VT323', monospace;
  }

  /* --- 2. CSS-ONLY MATRIX RAIN ANIMATION (No JS) --- */
  
  /* The Keyframe that moves code from top to bottom */
  @keyframes matrix-fall {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(100vh); } /* Drop continuously */
  }

  /* The Container for the rain */
  .rain-container {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0; /* Behind the content */
    pointer-events: none; /* Let users click through it */
  }

  /* The individual columns of code */
  .rain-col {
    position: absolute;
    top: -20%; /* Start slightly above screen */
    color: #0f0;
    font-size: 1.5rem;
    font-weight: bold;
    opacity: 0.4;
    user-select: none;
    writing-mode: vertical-rl; /* Makes text vertical */
    text-orientation: upright; /* Keeps letters upright */
    text-shadow: 0 0 10px #0f0; /* Green Glow */
    animation: matrix-fall linear infinite;
    white-space: nowrap;
  }

  /* --- Randomizing the Columns using CSS (No JS required) --- */
  /* We vary the Left position, Animation Speed, and Delay */
  .rain-col:nth-child(1) { left: 5%;  animation-duration: 6s; animation-delay: -2s; opacity: 0.3; }
  .rain-col:nth-child(2) { left: 15%; animation-duration: 9s; animation-delay: -4s; opacity: 0.2; }
  .rain-col:nth-child(3) { left: 25%; animation-duration: 7s; animation-delay: -1s; opacity: 0.4; }
  .rain-col:nth-child(4) { left: 35%; animation-duration: 10s;animation-delay: -6s; opacity: 0.2; }
  .rain-col:nth-child(5) { left: 45%; animation-duration: 5s; animation-delay: -3s; opacity: 0.5; }
  .rain-col:nth-child(6) { left: 55%; animation-duration: 8s; animation-delay: -5s; opacity: 0.3; }
  .rain-col:nth-child(7) { left: 65%; animation-duration: 6s; animation-delay: -2s; opacity: 0.4; }
  .rain-col:nth-child(8) { left: 75%; animation-duration: 11s;animation-delay: -7s; opacity: 0.2; }
  .rain-col:nth-child(9) { left: 85%; animation-duration: 7s; animation-delay: -1s; opacity: 0.3; }
  .rain-col:nth-child(10){ left: 95%; animation-duration: 9s; animation-delay: -4s; opacity: 0.2; }

  /* --- 3. UTILITIES --- */
  .matrix-text-glow { text-shadow: 0 0 5px #0f0, 0 0 10px #0f0; }
  .matrix-box-glow { box-shadow: 0 0 10px rgba(0, 255, 0, 0.2); }
  .matrix-border { border: 1px solid #00ff00; }
  
  /* Filter for Icons */
  .matrix-icon-filter {
    filter: brightness(0) saturate(100%) invert(46%) sepia(96%) saturate(1639%) hue-rotate(88deg) brightness(118%) contrast(118%);
  }

  /* --- 4. LOAD ANIMATION --- */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-on-load { animation: fadeUp 0.8s ease-out forwards; }
  .delay-100 { animation-delay: 0.1s; }
  .delay-200 { animation-delay: 0.2s; }
</style>

