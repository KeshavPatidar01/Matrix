            height: calc(100vh - 60px); 
            width: 100%;
            background-color: #0f172a;
            color: white;
            font-family: 'Segoe UI', sans-serif;
            overflow: hidden; /* Only hide overflow inside this container */
            position: relative;
            border-top: 1px solid #334155;
        }

        /* --- CANVAS & CONTAINER --- */
        #viewport {
            width: 100%;
            height: 100%;
            overflow: hidden;
            cursor: grab;
            position: relative;
            touch-action: none;
        }

        #map-container {
            position: absolute;
            top: 0; left: 0;
            transform-origin: 0 0;
            width: 1400px;
            height: 1600px;
        }

        /* --- NODES --- */
        .node {
            position: absolute;
            background: #1e293b;
            padding: 12px 20px;
            border-radius: 999px;
            border: 1px solid #334155;
            color: #e2e8f0;
            font-weight: 600;
            font-size: 14px;
            text-align: center;
            cursor: pointer;
            box-shadow: 0 4px 6px rgba(0,0,0,0.3);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            min-width: 140px;
            z-index: 10;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            user-select: none;
        }

        .node:hover {
            transform: scale(1.1);
            box-shadow: 0 0 15px rgba(96, 165, 250, 0.6);
            border-color: #60a5fa;
            z-index: 20;
            background: #0f172a;
        }

        /* Difficulty Colors/Glows */
        .glow-blue { box-shadow: 0 0 10px rgba(59, 130, 246, 0.1); }
        .glow-green { box-shadow: 0 0 10px rgba(16, 185, 129, 0.1); }
        .glow-purple { box-shadow: 0 0 10px rgba(168, 85, 247, 0.1); }
        .glow-red { box-shadow: 0 0 10px rgba(244, 63, 94, 0.1); }
        .glow-orange { box-shadow: 0 0 10px rgba(249, 115, 22, 0.1); }

        /* --- SVG LINES --- */
        .dsa-svg {
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            pointer-events: none;
            z-index: 1;
        }

        .dsa-path {
            fill: none;
            stroke: #475569;
            stroke-width: 2px;
            stroke-linecap: round;
            transition: stroke 0.3s;
        }

        /* --- INTERNAL UI ELEMENTS (Scoped absolute, not fixed) --- */
        .dsa-header {
            position: absolute; /* Changed from fixed to absolute */
            top: 20px; left: 20px;
            z-index: 30;
            pointer-events: none;
        }

        .dsa-controls {
            position: absolute; /* Changed from fixed to absolute */
            bottom: 20px; right: 20px;
            display: flex; gap: 10px; z-index: 30;
        }

        .btn-ctrl {
            width: 45px; height: 45px; border-radius: 50%;
            background: #1e293b; border: 1px solid #475569;
            color: white; font-size: 18px; cursor: pointer;
            display: grid; place-items: center;
            box-shadow: 0 4px 6px rgba(0,0,0,0.3);
            transition: 0.2s;
        }
        .btn-ctrl:active { transform: scale(0.95); }
        .btn-ctrl:hover { background: #334155; }

        /* --- MODAL --- */
        .dsa-modal {
            position: absolute; /* Changed from fixed */
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.8);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 50;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s;
            backdrop-filter: blur(2px);
        }
        .dsa-modal.active { opacity: 1; pointer-events: auto; }
        
        .dsa-modal-content {
            background: #1e293b;
            padding: 0;
            border-radius: 16px;
            width: 90%;
            max-width: 600px;
            max-height: 80%;
            border: 1px solid #475569;
            transform: scale(0.9);
            transition: transform 0.3s;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }
        .dsa-modal.active .dsa-modal-content { transform: scale(1); }

        .modal-header {
            padding: 20px;
            border-bottom: 1px solid #334155;
            display: flex; justify-content: space-between; align-items: center;
            background: #0f172a;
        }
        .modal-body {
            padding: 20px;
