        function drawLines() {
            const svg = document.getElementById('connections');
            // Select path inside dsa-roadmap-wrapper to avoid global query selector issues
            const existingPaths = svg.querySelectorAll('path:not(defs path)');
            existingPaths.forEach(p => p.remove());

            const containerRect = document.getElementById('map-container').getBoundingClientRect();

            connections.forEach(([startId, endId]) => {
                const start = document.getElementById(startId);
                const end = document.getElementById(endId);

                if (!start || !end) return;

                // Position relative to map-container
                const startLeft = start.offsetLeft + start.offsetWidth / 2;
                const startTop = start.offsetTop + start.offsetHeight;
                const endLeft = end.offsetLeft + end.offsetWidth / 2;
                const endTop = end.offsetTop;

                const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
                path.classList.add('dsa-path');
                
                const midY = (startTop + endTop) / 2;
                const d = `M ${startLeft} ${startTop} C ${startLeft} ${midY}, ${endLeft} ${midY}, ${endLeft} ${endTop}`;

                path.setAttribute("d", d);
                path.setAttribute("marker-end", "url(#arrow)");
                svg.appendChild(path);
            });
        }

        // --- PAN & ZOOM LOGIC ---
        const viewport = document.getElementById('viewport');
        const container = document.getElementById('map-container');
        
        let scale = 0.6; 
        let pointX = (viewport.offsetWidth - 1400 * scale) / 2;
        let pointY = 50;
        let isDragging = false;
        let startX, startY;

        function updateTransform() {
            container.style.transform = `translate(${pointX}px, ${pointY}px) scale(${scale})`;
        }

        viewport.addEventListener('mousedown', (e) => {
            isDragging = true;
            startX = e.clientX - pointX;
            startY = e.clientY - pointY;
            viewport.style.cursor = 'grabbing';
        });

        viewport.addEventListener('mousemove', (e) => {
            if (!isDragging) return;
            e.preventDefault();
            pointX = e.clientX - startX;
            pointY = e.clientY - startY;
            updateTransform();
        });

        viewport.addEventListener('mouseup', () => { isDragging = false; viewport.style.cursor = 'grab'; });
        viewport.addEventListener('mouseleave', () => { isDragging = false; viewport.style.cursor = 'grab'; });

        viewport.addEventListener('touchstart', (e) => {
            isDragging = true;
            startX = e.touches[0].clientX - pointX;
            startY = e.touches[0].clientY - pointY;
        }, {passive: false});

        viewport.addEventListener('touchmove', (e) => {
            if (!isDragging) return;
            e.preventDefault(); 
            pointX = e.touches[0].clientX - startX;
            pointY = e.touches[0].clientY - startY;
            updateTransform();
        }, {passive: false});

        viewport.addEventListener('touchend', () => isDragging = false);

        function zoomIn() { scale = Math.min(scale * 1.2, 2); updateTransform(); }
        function zoomOut() { scale = Math.max(scale / 1.2, 0.3); updateTransform(); }
        function resetView() {
            scale = window.innerWidth < 768 ? 0.4 : 0.7;
            pointX = (viewport.offsetWidth - 1400 * scale) / 2;
            pointY = 50;
            updateTransform();
        }

        // --- MODAL LOGIC ---
        function handleNodeClick(element) {
            const key = element.getAttribute('data-key');
            if (topicsData[key]) {
                openModal(topicsData[key].title, topicsData[key].questions);
            }
        }

        function openModal(title, questions) {
            document.getElementById('modal-title').innerText = title;
            const list = document.getElementById('modal-list');
            
            // Generate list items with numbers
            list.innerHTML = questions.map((q, index) => 
                `<li>
                    <span class="q-num">${index + 1}.</span>
                    <span>${q}</span>
                 </li>`
            ).join('');
            
            document.getElementById('dsa-modal').classList.add('active');
        }

        function closeModal(e) {
            if (e.target.id === 'dsa-modal') e.target.classList.remove('active');
        }

        window.onload = () => {
            drawLines();
            resetView();
        };
        window.onresize = resetView;
    


   
    </script>
</body>
