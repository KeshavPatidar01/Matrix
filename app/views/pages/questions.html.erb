<h1>Advanced Brain Search</h1>

<%= form_with url: search_path, method: :get, local: true do |form| %>
  <div>
    <%= form.text_field :q,  placeholder: "Kuch bhi pucho..." %>
    <%= form.submit "Search" %>
  </div>
  
  <div style="margin-top: 10px;">
    <%= form.check_box :ask_ai, { checked: params[:ask_ai] == "true" }, "true", "false" %>
    <%= form.label :ask_ai, "AI se Answer pucho (RAG mode)" %>
  </div>
<% end %>
<hr>


<h3>Search Results:</h3>
<%if @user_query.present?%>
<% @user_query.each do |result| %>
  <div class="result-item">
    <strong><%= result.question_title %></strong>
    <%# Agar description hai toh hi dikhao %>
    <p><%= result.try(:question_description) %></p> 
  </div>
<% end %>
<%end%>