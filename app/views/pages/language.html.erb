  var historyTraversal = event.persisted || 
                         ( typeof window.performance != "undefined" && 
                              window.performance.navigation.type === 2 );
  if ( historyTraversal ) {
    // Handle page restore.
    window.location.reload();
    if(performance.navigation.type == 2){
   location.reload(true);
}
  }
});
    </script>
