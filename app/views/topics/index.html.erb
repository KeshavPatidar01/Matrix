<%# Suggested location: app/views/topics/index.html.erb %>

<style>
  @import url('https://fonts.googleapis.com/css2?family=VT323&display=swap');

  /* --- 1. GLOBAL FONTS & COLORS --- */
  .matrix-theme-wrapper {
    font-family: 'VT323', monospace;
    min-height: 100vh;
    background-color: #000;
  }

  /* --- 2. CSS-ONLY MATRIX BACKGROUND --- */
  .matrix-bg-css {
    background-image: 
      linear-gradient(rgba(0, 255, 0, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 255, 0, 0.03) 1px, transparent 1px);
    background-size: 20px 20px;
    box-shadow: inset 0 0 100px rgba(0,0,0,0.9);
  }

  /* --- 3. RAIN ANIMATION (CSS ONLY) --- */
  @keyframes matrix-fall {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(100vh); }
  }

  .rain-container {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
    pointer-events: none;
  }

  .rain-col {
    position: absolute;
    top: -20%;
    color: #0f0;
    font-size: 1.5rem;
    font-weight: bold;
    opacity: 0.3;
    user-select: none;
    writing-mode: vertical-rl;
    text-orientation: upright;
    text-shadow: 0 0 10px #0f0;
    animation: matrix-fall linear infinite;
    white-space: nowrap;
  }

  /* Randomize Rain Columns */
  .rain-col:nth-child(1) { left: 5%;  animation-duration: 6s; animation-delay: -2s; }
  .rain-col:nth-child(2) { left: 15%; animation-duration: 9s; animation-delay: -4s; }
  .rain-col:nth-child(3) { left: 25%; animation-duration: 7s; animation-delay: -1s; }
  .rain-col:nth-child(4) { left: 35%; animation-duration: 10s;animation-delay: -6s; }
  .rain-col:nth-child(5) { left: 45%; animation-duration: 5s; animation-delay: -3s; }
  .rain-col:nth-child(6) { left: 55%; animation-duration: 8s; animation-delay: -5s; }
  .rain-col:nth-child(7) { left: 65%; animation-duration: 6s; animation-delay: -2s; }
  .rain-col:nth-child(8) { left: 75%; animation-duration: 11s;animation-delay: -7s; }
  .rain-col:nth-child(9) { left: 85%; animation-duration: 7s; animation-delay: -1s; }
  .rain-col:nth-child(10){ left: 95%; animation-duration: 9s; animation-delay: -4s; }

  /* --- 4. UTILITIES --- */
  .matrix-text-glow { text-shadow: 0 0 5px #0f0, 0 0 10px #0f0; }
  .matrix-box-glow { box-shadow: 0 0 10px rgba(0, 255, 0, 0.2); }
  .matrix-border { border: 1px solid #00ff00; }
  
  /* Status Colors */
  .text-matrix-green { color: #00ff00; }
  .text-matrix-dim { color: #004400; }
  .border-matrix-dim { border-color: #004400; }
</style>

<div class="matrix-theme-wrapper matrix-bg-css w-full overflow-x-hidden relative">

  <div class="rain-container">
      <div class="rain-col">1 0 1 A 4 F 2 0 9 1</div>
      <div class="rain-col">0 1 0 1 B 7 3 A 0 1</div>
      <div class="rain-col">A F 0 9 1 0 2 2 5 F</div>
      <div class="rain-col">1 0 1 0 4 2 0 1 0 0</div>
      <div class="rain-col">0 1 E 4 1 A 0 9 2 1</div>
      <div class="rain-col">1 0 1 0 4 2 0 1 0 3</div>
      <div class="rain-col">3 4 5 1 0 1 0 A B F</div>
      <div class="rain-col">1 0 1 0 4 2 0 1 0 1</div>
      <div class="rain-col">F F 0 1 A 9 1 0 2 0</div>
      <div class="rain-col">1 0 1 0 4 2 0 1 0 1</div>
  </div>

  <div class="container mx-auto p-4 md:p-8 relative z-10">

    <div class="text-center mb-10">
        <h1 class="text-4xl md:text-5xl font-extrabold text-white matrix-text-glow tracking-widest uppercase">
        > Select Data Module <span class="animate-pulse">_</span>
        </h1>
        <p class="text-green-600 mt-2 font-mono text-lg">Initialize learning sequence...</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">

      <% @topics.each_with_index do |topic, index| %>

        <%# ⬇️ LOGIC: CHECK IF PREVIOUS TOPIC IS COMPLETED %>
        <% previous_completed = true %>
        <% if index > 0 %>
          <% prev_topic = @topics[index - 1] %>
          <% previous_completed = current_user.user_topic_progresses
                                          .find_by(topic_id: prev_topic.id, completed: true)
                                          .present? %>
        <% end %>

        <%# --- CARD CONTAINER --- %>
        <div class="group bg-black border-2 p-6 md:p-8 overflow-hidden relative transition-all duration-300 ease-in-out
                    <%= previous_completed ? 'border-green-500 hover:-translate-y-2 hover:shadow-[0_0_20px_rgba(0,255,0,0.4)] cursor-pointer' : 'border-green-900 opacity-60 cursor-not-allowed' %>">
          
          <%# Background Scanline effect inside card %>
          <div class="absolute inset-0 bg-green-900 opacity-5 pointer-events-none group-hover:opacity-10 transition-opacity"></div>

          <div class="flex items-center mb-4 justify-between relative z-10">
              <span class="font-mono text-xl tracking-wider">
                  <% if previous_completed %>
                    <span class="text-green-400 font-bold">[ ACCESS GRANTED ]</span>
                  <% else %>
                    <span class="text-red-900 font-bold animate-pulse">[ ENCRYPTED ]</span>
                  <% end %>
              </span>
              
              <%# Icons %>
              <span class="<%= previous_completed ? 'text-green-500' : 'text-green-900' %> text-2xl">
                  <% if previous_completed %>
                    &#10004; <%# Checkmark %>
                  <% else %>
                    &#128274; <%# Lock %>
                  <% end %>
              </span>
          </div>

          <h2 class="text-2xl md:text-3xl font-bold mb-3 relative z-10">
            <% if previous_completed %>
              <%= link_to topic_path(topic), class: "block text-white group-hover:text-green-400 transition-colors duration-300 matrix-text-glow" do %>
                <%= topic.title %>
                <span class="inline-block opacity-0 group-hover:opacity-100 group-hover:translate-x-2 ml-2 text-green-500 transition-all duration-300">>></span>
              <% end %>
            <% else %>
              <span class="block text-gray-500 select-none">
                <%= topic.title %>
              </span>
            <% end %>
          </h2>

          <%# Animated Underline %>
          <div class="mt-4 h-1 w-12 rounded-full relative z-10 transition-all duration-500 
                      <%= previous_completed ? 'bg-green-700 group-hover:w-full group-hover:bg-green-400 group-hover:shadow-[0_0_10px_#0f0]' : 'bg-gray-800' %>"></div>

          <p class="mt-4 text-sm md:text-base relative z-10 font-mono <%= previous_completed ? 'text-green-700 group-hover:text-green-300' : 'text-gray-700' %> transition-colors">
            <%= truncate(topic.description, length: 100) %>
          </p>

        </div>
      <% end %>

    </div>


  </div>
</div>
