<style>
    @import url('https://fonts.googleapis.com/css2?family=VT323&display=swap');

    /* --- 1. GLOBAL FONTS & COLORS --- */
    .matrix-theme-wrapper {
    font-family: 'VT323', monospace;
    min-height: 100vh;
    background-color: #000;
    }

    /* --- 2. CSS-ONLY MATRIX BACKGROUND --- */
    .matrix-bg-css {
    background-image:
    linear-gradient(rgba(0, 255, 0, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 255, 0, 0.03) 1px, transparent 1px);
    background-size: 20px 20px;
    box-shadow: inset 0 0 100px rgba(0,0,0,0.9);
    }

    /* --- 3. RAIN ANIMATION (CSS ONLY) --- */
    @keyframes matrix-fall {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(100vh); }
    }

    .rain-container {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
    pointer-events: none;
    }

    .rain-col {
    position: absolute;
    top: -20%;
    color: #0f0;
    font-size: 1.5rem;
    font-weight: bold;
    opacity: 0.3;
    user-select: none;
    writing-mode: vertical-rl;
    text-orientation: upright;
    text-shadow: 0 0 10px #0f0;
    animation: matrix-fall linear infinite;
    white-space: nowrap;
    }

    /* Randomize Rain Columns */
    .rain-col:nth-child(1) { left: 5%;  animation-duration: 6s; animation-delay: -2s; }
    .rain-col:nth-child(2) { left: 15%; animation-duration: 9s; animation-delay: -4s; }
    .rain-col:nth-child(3) { left: 25%; animation-duration: 7s; animation-delay: -1s; }
    .rain-col:nth-child(4) { left: 35%; animation-duration: 10s;animation-delay: -6s; }
    .rain-col:nth-child(5) { left: 45%; animation-duration: 5s; animation-delay: -3s; }
    .rain-col:nth-child(6) { left: 55%; animation-duration: 8s; animation-delay: -5s; }
    .rain-col:nth-child(7) { left: 65%; animation-duration: 6s; animation-delay: -2s; }
    .rain-col:nth-child(8) { left: 75%; animation-duration: 11s;animation-delay: -7s; }
    .rain-col:nth-child(9) { left: 85%; animation-duration: 7s; animation-delay: -1s; }
    .rain-col:nth-child(10){ left: 95%; animation-duration: 9s; animation-delay: -4s; }

    /* --- 4. UTILITIES --- */
    .matrix-text-glow { text-shadow: 0 0 5px #0f0, 0 0 10px #0f0; }
    .matrix-box-glow { box-shadow: 0 0 10px rgba(0, 255, 0, 0.2); }
    .matrix-border { border: 1px solid #00ff00; }
</style>

<div class="matrix-theme-wrapper matrix-bg-css w-full overflow-x-hidden relative">

  <div class="rain-container">
    <div class="rain-col">1 0 1 A 4 F 2 0 9 1</div>
    <div class="rain-col">0 1 0 1 B 7 3 A 0 1</div>
    <div class="rain-col">A F 0 9 1 0 2 2 5 F</div>
    <div class="rain-col">1 0 1 0 4 2 0 1 0 0</div>
    <div class="rain-col">0 1 E 4 1 A 0 9 2 1</div>
    <div class="rain-col">1 0 1 0 4 2 0 1 0 3</div>
    <div class="rain-col">3 4 5 1 0 1 0 A B F</div>
    <div class="rain-col">1 0 1 0 4 2 0 1 0 1</div>
    <div class="rain-col">F F 0 1 A 9 1 0 2 0</div>
    <div class="rain-col">1 0 1 0 4 2 0 1 0 1</div>
  </div>

  <div class="max-w-6xl mx-auto my-12 px-4 relative z-10">

    <div class="text-center mb-10 border-b border-green-900 pb-6">
      <h2 class="text-4xl md:text-5xl font-extrabold text-white matrix-text-glow tracking-widest uppercase">
        > Saved Data Blocks <span class="animate-pulse">_</span>
      </h2>
      <p class="text-green-700 font-mono mt-2">Accessing storage....</p>
    </div>

    <% if @notes.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <% @notes.each_with_index do |note, i| %>

          <%# --- NOTE CARD --- %>
          <div class="bg-gray-900 bg-opacity-80 p-6 rounded-sm border border-green-900 hover:border-green-500 hover:shadow-[0_0_15px_rgba(0,255,0,0.3)] transition duration-300 group flex flex-col justify-between h-full">

            <div>
              <div class="flex justify-between items-start mb-3">
                <span class="text-green-800 text-xs font-mono">[ID:<%= i + 1 %>                ]</span>
                <div class="h-2 w-2 rounded-full bg-green-900 group-hover:bg-green-500 group-hover:shadow-[0_0_5px_#0f0] transition-colors"></div>
              </div>

              <h3 class="text-2xl font-bold text-white mb-3 group-hover:text-green-300 transition-colors">                <span class="text-green-600 mr-2">></span><%= note.note_title %></h3>              <p class="text-green-500 text-opacity-80 mb-5 text-wrap font-mono text-lg leading-relaxed border-l-2 border-green-900 pl-3"><%= note.note_description %></p>          </div>

          <div class="flex justify-end space-x-3 pt-4 border-t border-green-900 border-dashed">
            <%# Uncomment below to enable Edit button style %>
            <%# = link_to "[ EDIT ]", edit_note_path(note), class: "text-yellow-500 hover:text-yellow-300 font-bold font-mono transition duration-200" %>

            <%= button_to "[ PURGE DATA ]", note, method: :delete, data: { confirm: "Confirm deletion of data block?" }, class: "px-4 py-2 border border-red-900 text-red-700 hover:bg-red-900 hover:text-white hover:border-red-500 font-mono text-sm font-bold rounded-sm transition cursor-pointer duration-200 uppercase tracking-wider" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>

      <%# --- EMPTY STATE --- %>
      <div class="text-center mt-20 p-10 border border-green-900 border-dashed bg-black bg-opacity-50">
        <p class="text-green-500 text-2xl font-mono animate-pulse">
            > MEMORY BUFFER EMPTY
        </p>
        <p class="text-gray-500 mt-2 font-mono">Create a new data block to initialize storage.</p>

        <div class="mt-6">
          <%= link_to "Create Note", new_note_path, class: "inline-block px-6 py-2 border border-green-500 text-green-500 hover:bg-green-500 hover:text-black font-bold font-mono transition-all duration-300" %>
        </div>
      </div>

    <% end %>
  </div>

</div>
