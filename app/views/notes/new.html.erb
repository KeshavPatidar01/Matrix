<style>
    @import url('https://fonts.googleapis.com/css2?family=VT323&display=swap');

    /* --- 1. GLOBAL FONTS & COLORS --- */
    .matrix-theme-wrapper {
    font-family: 'VT323', monospace;
    min-height: 100vh;
    background-color: #000;
    }

    /* --- 2. CSS-ONLY MATRIX BACKGROUND --- */
    .matrix-bg-css {
    background-image:
    linear-gradient(rgba(0, 255, 0, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 255, 0, 0.03) 1px, transparent 1px);
    background-size: 20px 20px;
    box-shadow: inset 0 0 100px rgba(0,0,0,0.9);
    }

    /* --- 3. RAIN ANIMATION (CSS ONLY) --- */
    @keyframes matrix-fall {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(100vh); }
    }

    .rain-container {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
    pointer-events: none;
    }

    .rain-col {
    position: absolute;
    top: -20%;
    color: #0f0;
    font-size: 1.5rem;
    font-weight: bold;
    opacity: 0.3;
    user-select: none;
    writing-mode: vertical-rl;
    text-orientation: upright;
    text-shadow: 0 0 10px #0f0;
    animation: matrix-fall linear infinite;
    white-space: nowrap;
    }

    /* Randomize Rain Columns */
    .rain-col:nth-child(1) { left: 5%;  animation-duration: 6s; animation-delay: -2s; }
    .rain-col:nth-child(2) { left: 15%; animation-duration: 9s; animation-delay: -4s; }
    .rain-col:nth-child(3) { left: 25%; animation-duration: 7s; animation-delay: -1s; }
    .rain-col:nth-child(4) { left: 35%; animation-duration: 10s;animation-delay: -6s; }
    .rain-col:nth-child(5) { left: 45%; animation-duration: 5s; animation-delay: -3s; }
    .rain-col:nth-child(6) { left: 55%; animation-duration: 8s; animation-delay: -5s; }
    .rain-col:nth-child(7) { left: 65%; animation-duration: 6s; animation-delay: -2s; }
    .rain-col:nth-child(8) { left: 75%; animation-duration: 11s;animation-delay: -7s; }
    .rain-col:nth-child(9) { left: 85%; animation-duration: 7s; animation-delay: -1s; }
    .rain-col:nth-child(10){ left: 95%; animation-duration: 9s; animation-delay: -4s; }

    /* --- 4. UTILITIES --- */
    .matrix-text-glow { text-shadow: 0 0 5px #0f0, 0 0 10px #0f0; }
    .matrix-box-glow { box-shadow: 0 0 15px rgba(0, 255, 0, 0.15); }
    .matrix-border { border: 1px solid #00ff00; }

    /* Input Fields Style */
    .matrix-input {
    background-color: #050505; /* Black */
    border: 1px solid #004400; /* Dark Green Border */
    color: #00ff00; /* Neon Text */
    font-family: 'VT323', monospace;
    letter-spacing: 1px;
    font-size: 1.1rem;
    }
    .matrix-input:focus {
    outline: none;
    border-color: #00ff00;
    box-shadow: 0 0 10px rgba(0, 255, 0, 0.3);
    }
    .matrix-input::placeholder {
    color: #004400;
    }
</style>

<div class="matrix-theme-wrapper matrix-bg-css w-full min-h-screen flex items-center justify-center relative overflow-hidden">

  <div class="rain-container">
    <div class="rain-col">1 0 1 A 4 F 2 0 9 1</div>
    <div class="rain-col">0 1 0 1 B 7 3 A 0 1</div>
    <div class="rain-col">A F 0 9 1 0 2 2 5 F</div>
    <div class="rain-col">1 0 1 0 4 2 0 1 0 0</div>
    <div class="rain-col">0 1 E 4 1 A 0 9 2 1</div>
    <div class="rain-col">1 0 1 0 4 2 0 1 0 3</div>
    <div class="rain-col">3 4 5 1 0 1 0 A B F</div>
    <div class="rain-col">1 0 1 0 4 2 0 1 0 1</div>
    <div class="rain-col">F F 0 1 A 9 1 0 2 0</div>
    <div class="rain-col">1 0 1 0 4 2 0 1 0 1</div>
  </div>

  <div class="w-full px-4 relative z-10">

    <div class="text-center mb-8">
      <h1 class="text-4xl text-white matrix-text-glow font-bold uppercase">> New Entry <span class="animate-pulse">_</span></h1>
    </div>

    <%= form_with(model: @note, local: true, data: { turbo: false }, class: "max-w-lg mx-auto bg-gray-900 bg-opacity-90 matrix-border matrix-box-glow p-8 rounded-sm") do |form| %>

      <div class="mb-6">
        <%= form.label :note_title, "> INPUT TITLE:", class: "block text-green-500 font-bold mb-2 font-mono tracking-widest" %>
        <%= form.text_field :note_title, placeholder: "Enter filename....", class: "w-full px-4 py-3 rounded-sm matrix-input" %>
      </div>

      <div class="mb-6">
        <%= form.label :note_description, "> INPUT DATA:", class: "block text-green-500 font-bold mb-2 font-mono tracking-widest" %>
        <%= form.text_area :note_description, rows: 5, placeholder: "Enter data....", class: "w-full px-4 py-3 rounded-sm matrix-input" %>
      </div>

      <div class="border-t border-green-900 pt-4 mt-6">
        <p class="text-green-800 text-sm font-mono mb-4 text-center">
            System Notice: Return navigation enabled post-save.
        </p>

        <div class="flex justify-between items-center">
          <%# = link_to "< ABORT", notes_path, class: "text-red-900 hover:text-red-500 font-bold font-mono transition-colors" %>

          <%= form.submit "[ SAVE TO THE MEMORY ]", class: "bg-black border border-green-500 text-green-500 hover:bg-green-500 hover:text-black font-bold py-2 px-6 rounded-sm transition duration-300 cursor-pointer shadow-[0_0_10px_rgba(0,255,0,0.2)] font-mono text-lg uppercase tracking-wider" %>
        </div>
      </div>

    <% end %>
  </div>

</div>
